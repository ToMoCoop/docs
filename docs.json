{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ClarusWMS",
  "colors": {
    "primary": "#1D4763",
    "light": "#6B9DC2",
    "dark": "#B1C5DE"
  },
  "favicon": "/favicon.png",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"],
      "defaults": "all"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "public": true,
        "groups": [
          {
            "group": "Overview",
            "pages": ["index"]
          },
          {
            "group": "Integrations",
            "pages": ["integrations/cloudprint"]
          }
        ]
      },
      {
        "tab": "Architecture",
        "groups": [
          {
            "group": "AI Architecture",
            "pages": [
              "architecture/ai/overview",
              "architecture/ai/infrastructure",
              "architecture/ai/gateways",
              "architecture/ai/runtime",
              "architecture/ai/authentication",
              "architecture/ai/tools",
              "architecture/ai/sessions",
              "architecture/ai/frontend"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "architecture/deployment/index",
              "architecture/deployment/ai-pipelines"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Documentation",
            "public": true,
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Core Resources",
            "pages": ["api-reference/core-resources/address"]
          },
          {
            "group": "Operations",
            "openapi": "api-reference/clarus-api.json",
            "public": true
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Support",
      "href": "https://support.claruswms.com"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://uk.linkedin.com/company/claruswms",
      "youtube": "https://www.youtube.com/@claruswms"
    }
  }
}